/* pages/ai-order/ai-order.wxss */

page {
  height: 100vh;
  background: linear-gradient(180deg, #fff9f4 0%, #f8f7ff 56%, #ffffff 100%);
  overflow: hidden;
}

.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* ==================== 自定义导航栏 ==================== */
.nav-bar {
  flex-shrink: 0;
  position: relative;
}

.nav-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 32rpx;
  position: relative;
}

.nav-back {
  position: absolute;
  left: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.nav-back-icon {
  width: 16rpx;
  height: 16rpx;
  border-left: 4rpx solid #333;
  border-bottom: 4rpx solid #333;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
}

/* ==================== 主滚动区 ==================== */
.main-scroll {
  flex: 1;
  min-height: 0;
}

.scroll-inner {
  padding: 0 36rpx;
}

/* ==================== Hero 区域 ==================== */
.hero-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx 20rpx;
  text-align: center;
}

.hero-compact {
  padding: 24rpx 20rpx 8rpx;
}

.assistant-avatar {
  margin-bottom: 24rpx;
}

.avatar-bg {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC02 40%, #FF8A65 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(200, 150, 50, 0.2);
}

.avatar-icon {
  font-size: 56rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.25;
  margin-bottom: 16rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #8B7355;
  line-height: 1.5;
  max-width: 480rpx;
}

.hero-title-small {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.hero-subtitle-small {
  font-size: 26rpx;
  color: #999;
}

/* ==================== Prompt 快捷需求 ==================== */
.prompt-section {
  padding: 16rpx 0 24rpx;
}

.prompt-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.prompt-chips {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.prompt-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.7);
  border: 1rpx solid #EDE7DF;
  border-radius: 20rpx;
  backdrop-filter: blur(12rpx);
  transition: background 0.2s;
}

.prompt-chip:active {
  background: rgba(255, 255, 255, 0.92);
  border-color: #D4C8B8;
}

.chip-emoji {
  font-size: 32rpx;
  flex-shrink: 0;
}

.chip-text {
  font-size: 26rpx;
  color: #4a4a4a;
  line-height: 1.4;
}

/* ==================== Loading ==================== */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #C4A882;
  animation: dotPulse 1.4s ease-in-out infinite;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dotPulse {
  0%, 80%, 100% {
    opacity: 0.25;
    transform: scale(0.7);
  }
  40% {
    opacity: 1;
    transform: scale(1);
  }
}

.loading-text {
  font-size: 28rpx;
  color: #8B7355;
  font-weight: 500;
}

/* ==================== 错误区域 ==================== */
.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  text-align: center;
}

.error-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.error-action {
  padding: 16rpx 40rpx;
  background: #FFF;
  border: 1rpx solid #E0D8CF;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #8B7355;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.error-action:active {
  background: #FAF5EE;
}

/* ==================== 推荐结果卡片 ==================== */
.results-section {
  padding-top: 8rpx;
}

.result-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(12rpx);
  border: 1rpx solid #EDE7DF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.match-tag {
  font-size: 22rpx;
  font-weight: 700;
  color: #FFF;
  background: linear-gradient(135deg, #C4A882 0%, #A0785A 100%);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}

.option-tags {
  display: flex;
  gap: 8rpx;
}

.option-tag {
  font-size: 22rpx;
  color: #8B7355;
  background: #FAF3EA;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid #E8DCC8;
}

/* 卡片主体 */
.card-body {
  display: flex;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.card-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #F3EFEA;
}

.card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  margin-bottom: 10rpx;
}

.card-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #C4A882;
}

/* 推荐理由 */
.card-reason {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding: 16rpx;
  background: #FAFAF7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.reason-icon {
  font-size: 24rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.reason-text {
  font-size: 24rpx;
  color: #6B6B6B;
  line-height: 1.5;
  flex: 1;
}

/* 选择规格按钮 */
.card-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 18rpx;
  background: linear-gradient(135deg, #8B7355 0%, #6B5B4A 100%);
  border-radius: 16rpx;
  color: #FFF;
  box-shadow: 0 4rpx 12rpx rgba(107, 91, 74, 0.2);
}

.card-action:active {
  opacity: 0.88;
}

.action-text {
  font-size: 28rpx;
  font-weight: 600;
}

.action-arrow {
  font-size: 24rpx;
  font-weight: 700;
}

/* 重新推荐按钮 */
.retry-section {
  display: flex;
  justify-content: center;
  padding: 16rpx 0 8rpx;
}

.retry-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 44rpx;
  background: #FFF;
  border: 1rpx solid #E0D8CF;
  border-radius: 48rpx;
  font-size: 26rpx;
  color: #8B7355;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.retry-btn:active {
  background: #FAF5EE;
}

.retry-icon {
  font-size: 28rpx;
}

/* 底部留白 */
.bottom-spacer {
  height: 200rpx;
}

/* ==================== 底部输入区域 ==================== */
.input-zone {
  flex-shrink: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.input-row {
  display: flex;
  align-items: flex-end;
  gap: 16rpx;
  background: #FFF;
  border: 1rpx solid #E8E0D8;
  border-radius: 28rpx;
  padding: 12rpx 12rpx 12rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #1a1a1a;
  line-height: 1.5;
  max-height: 120rpx;
  min-height: 40rpx;
  padding: 6rpx 0;
}

.send-btn {
  flex-shrink: 0;
  padding: 18rpx 32rpx;
  background: #E0D8CF;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #A89B8B;
  transition: all 0.2s;
}

.send-btn.active {
  background: linear-gradient(135deg, #8B7355 0%, #6B5B4A 100%);
  color: #FFF;
  box-shadow: 0 4rpx 14rpx rgba(107, 91, 74, 0.25);
}

.send-btn.active:active {
  opacity: 0.85;
}

.send-btn.disabled {
  opacity: 0.6;
  pointer-events: none;
}

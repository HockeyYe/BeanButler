/* pages/checkout/checkout.wxss */
page {
  background-color: #F7F7F7;
  height: 100vh;
}

.checkout-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.checkout-scroll {
  flex: 1;
  height: 0;
}

.padding-spacer {
  /* 确保底部留出足够空间避开固定结算栏 */
  padding: 24rpx 30rpx calc(180rpx + env(safe-area-inset-bottom)) 30rpx;
}

/* 卡片基础样式 */
.section-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

/* 1. 会员等级区域样式 */
.member-rights {
  display: flex;
  flex-direction: column;
}

.member-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.member-tag {
  background-color: #000000;
  color: #FFFFFF;
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  margin-right: 16rpx;
  font-weight: 500;
}

.rights-title {
  font-size: 28rpx;
  font-weight: 600;
}

.rights-detail {
  display: flex;
  justify-content: space-between;
  font-size: 24rpx;
  color: #666666;
}

.discount-val {
  color: #000000;
  font-weight: 500;
}

/* 2. 商品明细卡片样式 */
.checkout-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  margin-bottom: 10rpx;
}

.item-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-header {
  display: grid;                  /* 改用 Grid 佈局 */
  grid-template-columns: 1fr auto; /* 左側自適應，右側根據內容(價格)自動寬度 */
  column-gap: 20rpx;              /* 設置名字與價格之間的固定間距 */
  align-items: start;
  width: 100%;
  box-sizing: border-box;
}

/* 修改 checkout.wxss 中的 .item-name */
.item-name {
  flex: 1;                /* 佔用左側所有空間 */
  min-width: 0;           /* 🔥 極其重要：沒有這行，flex 容器會被長文字撐破 */
  display: block;         /* 確保是區塊顯示 */
  
  /* 省略號三件套 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;

  font-size: 30rpx;
  color: #000;
}

.item-price {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;         /* 🛑 絕對禁止縮小 */
  width: 160rpx;          /* 👈 這裡給一個固定的寬度，確保能放下 "MOP 19.0" */
  text-align: right;      /* 文字靠右對齊 */
  margin-left: 20rpx;     /* 與名字保持間距 */
  white-space: nowrap;    /* 價格絕不換行 */
  font-weight: bold;
}

.item-header-sub {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.item-customText {
  font-size: 22rpx;
  color: #999999;
  flex: 1; 
  margin-right: 20rpx;
}

.item-quantity {
  font-size: 24rpx;
  color: #333333;
}

/* 3. 卡券与时间选择复用行样式 */
.coupon-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 10rpx 0;
}

.coupon-label {
  font-size: 26rpx;
  color: #666666; 
}

.coupon-right {
  display: flex;
  align-items: center;
}

.coupon-desc {
  font-size: 24rpx;
  color: #999999;
  margin-right: 12rpx;
}

/* 当时间非“立即取餐”或优惠券选中时高亮变黑 */
.coupon-desc.selected {
  color: #000000;
  font-weight: 500;
}

.arrow-right {
  font-size: 32rpx;
  color: #CCCCCC;
}

.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 30rpx 0;
}

/* 3.2 费用小记样式 (主要用于折扣展示) */
.price-summary {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666666;
}

.row-val {
  color: #333333;
}

.discount-green {
  color: #389E0D;
  font-weight: 500;
}

/* ================= 4. 居右对齐的最终小计与咖啡豆 ================= */
.final-summary-wrap {
  display: flex;
  flex-direction: column;
  align-items: flex-end; /* 核心：让内部两行文字全部居右对齐 */
}

.final-subtotal {
  display: flex;
  align-items: baseline;
}

.fs-label {
  font-size: 26rpx; /* "小计"标签与优惠券字号相同 */
  color: #333333;
  margin-right: 12rpx;
}

.fs-val {
  font-size: 35rpx; /* 严格设为26rpx的2倍 */
  font-weight: 700;
  color: #000000;
}

.final-beans {
  display: flex;
  align-items: center;
}

.fb-text {
  font-size: 26rpx; /* 与优惠券字体同级 */
  color: #666666;
}

.fb-icon {
  width: 50rpx;
  height: 50rpx;
  display: block;
}

/* ================= 5. 底部固定结算栏样式 ================= */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom)) 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.03);
  z-index: 100;
  width: 100%;
  box-sizing: border-box;
}

.price-wrap {
  display: flex;
  align-items: baseline;
  flex: 1;
}

.total-label {
  font-size: 28rpx;
  color: #333333;
  margin-right: 16rpx;
}

.total-price {
  font-size: 35rpx;
  font-weight: 700;
  color: #000000;
}

.confirm-btn {
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 0 60rpx !important;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0 !important;
  width: auto !important;
  flex-shrink: 0;
}

.confirm-btn:active {
  opacity: 0.8;
}
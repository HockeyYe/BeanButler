/* pages/coupons/coupons.wxss */
page {
  background-color: #F7F7F7;
  height: 100vh;
}

.coupons-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  height: 100rpx;
  position: relative;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #999999;
  position: relative;
  transition: color 0.2s;
}

.tab-item.active {
  color: #000000;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 50rpx;
  height: 6rpx;
  background-color: #000000;
  border-radius: 4rpx;
}

/* 优惠券列表 */
.coupons-list {
  flex: 1;
  padding: 24rpx 30rpx;
  box-sizing: border-box;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* 优惠券卡片 */
.coupon-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.coupon-card.disabled-card {
  opacity: 0.6;
  filter: grayscale(100%);
}

.coupon-left {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  border-right: 2rpx dashed #EEEEEE; 
  margin-right: 30rpx;
  flex-shrink: 0;
}

.coupon-value {
  font-size: 48rpx; 
  font-weight: 600;
  color: #000000;
}

/* ================== 核心修复区域 ================== */
.coupon-right {
  flex: 1;
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-width: 0; /* 核心修复：防止内部元素把外部撑爆 */
}

.coupon-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  padding-right: 20rpx;
  min-width: 0; /* 核心修复：防止文本被按钮挤压成竖排 */
}

/* 对文字加上单行省略号保护，防止超长文字破坏版面 */
.coupon-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.coupon-condition {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.coupon-expire {
  font-size: 22rpx;
  color: #999999;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.coupon-action {
  flex-shrink: 0; /* 保护按钮不被压缩 */
}

/* 黑底极简按钮 */
.use-btn {
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 0 !important; /* 清除默认内边距干扰 */
  width: 150rpx !important; /* 强行锁死宽度，防止被默认样式放大 */
  height: 60rpx;
  line-height: 60rpx;
  margin: 0;
  border: none;
  font-weight: 500;
}

.use-btn:active {
  opacity: 0.8;
}

/* 纯 CSS 绘制的倾斜印章 */
.stamp-text {
  font-size: 24rpx;
  font-weight: 600;
  color: #999999;
  border: 3rpx solid #CCCCCC;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  transform: rotate(-15deg);
}
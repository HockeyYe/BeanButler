<view class="container">
  <view class="form">
    <view class="form-item">
      <text class="label">姓名 <text class="required">*</text></text>
      <input type="text" value="{{name}}" bindinput="onNameInput" placeholder="請輸入真實姓名" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="label">學號 <text class="required">*</text></text>
      <input type="text" value="{{student_id}}" bindinput="onStudentIdInput" placeholder="請輸入學號" maxlength="20" />
    </view>

    <view class="form-item">
      <text class="label">聯絡電話 <text class="required">*</text></text>
      <input type="number" value="{{phone}}" bindinput="onPhoneInput" placeholder="請輸入手機號碼" maxlength="11" />
    </view>

  </view>

  <button class="btn-primary" bindtap="saveProfile">保存並返回</button>
</view>
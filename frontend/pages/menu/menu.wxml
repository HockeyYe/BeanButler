<view class="menu-page">


<view class="ai-order-entry" bindtap="goToAiOrder">
  <view class="ai-order-entry-left">
    <view class="ai-order-entry-icon">🤖</view>
    <view class="ai-order-entry-text">
      <text class="ai-order-entry-title">AI 帮我点</text>
      <text class="ai-order-entry-desc">说出口味、温度或预算，让 AI 推荐适合你的咖啡</text>
    </view>
  </view>
  <view class="ai-order-entry-arrow">→</view>
</view>

<!-- 下方才开始左右分区 -->
<view class="menu-container">
  <!-- 左侧分类 -->
  <scroll-view
    class="category-side"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="nav-{{currentCategory}}"
  >
    <view
      wx:for="{{categories}}"
      wx:key="index"
      id="nav-{{index}}"
      class="category-item {{currentCategory === index ? 'active' : ''}}"
      bindtap="switchCategory"
      data-index="{{index}}"
    >
      {{item}}
    </view>
  </scroll-view>

  <!-- 右侧商品 -->
  <scroll-view
    class="product-side"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    scroll-into-view="{{toView}}"
    bindscroll="onScroll"
    scroll-with-animation
  >
    <view class="page-main">
      <view class="padding-bottom-spacer">
        <view wx:for="{{menuList}}" wx:key="id" id="{{item.id}}" class="category-section">
          <view class="section-title">{{item.name}}</view>

          <view
            wx:for="{{item.items}}"
            wx:for-item="product"
            wx:key="id"
            class="product-row"
            bindtap="openCustomize"
            data-product="{{product}}"
          >
            <image
              src="{{product.image}}"
              mode="aspectFill"
              class="product-image"
            ></image>

            <view class="product-info">
              <view class="product-name-row">
                <text class="recommend-tag" wx:if="{{item.name === '為你推荐' || item.name === '為你推薦' || item.name === '为你推荐' || item.name === '为你推薦'}}">AI推荐</text>
                <text class="product-name">{{product.name}}</text>
              </view>

              <text class="product-desc">{{product.desc}}</text>

              <view class="product-bottom">
                <text class="product-price">MOP {{product.price}}</text>
                <view class="add-btn">+</view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
</view>

<view class="cart-bar" wx:if="{{cartTotalItems > 0 && !showCustomize}}">
<view class="cart-left" bindtap="showCartDetail">
  <view class="cart-icon-wrap">
    <image class="cart-icon" src="/images/icon_cart.png"></image>
    <view class="cart-badge">{{cartTotalItems}}</view>
  </view>
  <text class="cart-total">MOP {{cartTotalAmount}}</text>
</view>
<view class="cart-right">
  <button class="checkout-btn" bindtap="goToCheckout">结算</button>
</view>
</view>

<view class="customize-modal" wx:if="{{showCustomize}}">
<view class="modal-mask" bindtap="closeCustomize"></view>
<view class="modal-content">
  <scroll-view scroll-y class="modal-scroll" enhanced show-scrollbar="{{false}}">
    <image src="{{currentProduct.image}}" mode="aspectFill" class="modal-hero-img"></image>

    <view class="modal-body">
      <view class="modal-header-row">
        <text class="modal-title">{{currentProduct.name}}</text>
        <text class="modal-price">MOP {{currentProduct.price}}</text>
      </view>

      <text class="modal-desc">{{currentProduct.desc}}</text>

      <view class="divider"></view>

      <view class="sku-group" wx:if="{{beanOptions.length > 0}}">
        <text class="sku-title">咖啡豆</text>
        <view class="sku-tags">
          <view
            wx:for="{{beanOptions}}"
            wx:key="*this"
            class="sku-tag {{customization.bean === item ? 'active' : ''}}"
            bindtap="selectOption"
            data-type="bean"
            data-val="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view class="sku-group" wx:if="{{iceOptions.length > 0}}">
        <text class="sku-title">温度</text>
        <view class="sku-tags">
          <view
            wx:for="{{iceOptions}}"
            wx:key="*this"
            class="sku-tag {{customization.ice === item ? 'active' : ''}}"
            bindtap="selectOption"
            data-type="ice"
            data-val="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view class="sku-group" wx:if="{{sweetnessOptions.length > 0}}">
        <text class="sku-title">甜度</text>
        <view class="sku-tags">
          <view
            wx:for="{{sweetnessOptions}}"
            wx:key="*this"
            class="sku-tag {{customization.sweetness === item ? 'active' : ''}}"
            bindtap="selectOption"
            data-type="sweetness"
            data-val="{{item}}"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view class="quantity-group">
        <text class="sku-title">数量</text>
        <view class="quantity-control">
          <view class="q-btn" bindtap="changeQuantity" data-diff="-1">-</view>
          <view class="q-num">{{customization.quantity}}</view>
          <view class="q-btn" bindtap="changeQuantity" data-diff="1">+</view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="modal-footer">
    <button class="btn-primary" bindtap="addToCart">加入购物车</button>
  </view>
</view>
</view>

<view class="cart-detail-modal" wx:if="{{showCartDetailModal}}">
<view class="modal-mask" bindtap="closeCartDetailModal"></view>
<view class="cart-content">
  <view class="cart-header">
    <text class="cart-title">已选商品</text>
    <text class="cart-clear" bindtap="clearCartItems">清空</text>
  </view>

  <scroll-view class="cart-list" scroll-y enhanced show-scrollbar="{{false}}">
    <view wx:for="{{cartDetailList}}" wx:key="id" wx:for-index="index" class="cart-item">
      <view class="item-info">
        <text class="item-name">{{item.name}}</text>
        <text class="item-custom">{{item.customText}}</text>
        <text class="item-price">MOP {{item.price}}</text>
      </view>

      <view class="quantity-control mini-q">
        <view class="q-btn" bindtap="removeFromCart" data-index="{{index}}">-</view>
        <view class="q-num">{{item.quantity}}</view>
        <view class="q-btn" bindtap="incrementCartItem" data-index="{{index}}">+</view>
      </view>
    </view>
  </scroll-view>
</view>
</view>

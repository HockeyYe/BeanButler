/* pages/menu/menu.wxss */
page {
  background-color: #FFFFFF;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.menu-page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
}

.ai-order-entry {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  margin: 16rpx 20rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  box-shadow: 0 4rpx 16rpx rgba(15, 52, 96, 0.25);
}

.ai-order-entry-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.ai-order-entry-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 14rpx;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.ai-order-entry-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.ai-order-entry-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
}

.ai-order-entry-desc {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.ai-order-entry-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-left: 12rpx;
  flex-shrink: 0;
}
/* ================= 主体左右分区 ================= */
.menu-container {
  display: flex;
  flex: 1;
  overflow: hidden;
  background: #FFFFFF;
}

.category-side {
  width: 180rpx;
  background-color: #F7F7F7;
  height: 100%;
  flex-shrink: 0;
}

.category-item {
  padding: 40rpx 20rpx;
  text-align: center;
  font-size: 28rpx;
  color: #999999;
  position: relative;
  transition: all 0.2s;
}

.category-item.active {
  color: #000000;
  font-weight: 600;
  background-color: #FFFFFF;
}

.product-side {
  flex: 1;
  height: 100%;
  background-color: #FFFFFF;
}

.page-main {
  min-height: 100%;
}

.padding-bottom-spacer {
  padding-bottom: 350rpx;
}

.category-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  padding: 40rpx 0 20rpx 0;
}

.product-row {
  display: flex;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.product-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  background-color: #F0F0F0;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.recommend-tag {
  font-size: 20rpx;
  background-color: #000000;
  color: #FFFFFF;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-right: 10rpx;
  font-weight: 400;
  vertical-align: middle;
}

.product-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #000000;
}

.product-desc {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.product-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
}

.add-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 50%;
  text-align: center;
  line-height: 44rpx;
  font-size: 36rpx;
  font-weight: 300;
}

/* ================= 购物车悬浮条 ================= */
.cart-bar {
  position: fixed;
  bottom: 180rpx;
  left: 30rpx;
  right: 30rpx;
  height: 110rpx;
  background-color: #000000;
  border-radius: 55rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 10rpx 0 40rpx;
  z-index: 100;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}

.cart-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.cart-icon-wrap {
  position: relative;
  margin-right: 30rpx;
}

.cart-icon {
  width: 50rpx;
  height: 50rpx;
  filter: brightness(0) invert(1);
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -15rpx;
  background-color: #FF4D4F;
  color: white;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.cart-total {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.checkout-btn {
  background-color: #FFFFFF;
  color: #000000;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0 40rpx;
  height: 80rpx;
  line-height: 80rpx;
  margin: 0;
}

/* ================= 商品规格选择弹窗 ================= */
.customize-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0,0,0,0.5);
}

.modal-content {
  position: relative;
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.modal-scroll {
  width: 100%;
  max-height: calc(85vh - 140rpx - env(safe-area-inset-bottom));
}

.modal-hero-img {
  width: 100%;
  aspect-ratio: 1 / 1;
  background-color: #F7F7F7;
  display: block;
  flex-shrink: 0;
}

.modal-body {
  padding: 40rpx 30rpx 60rpx 30rpx;
  background-color: #FFFFFF;
}

.modal-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #000000;
}

.modal-price {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
}

.modal-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 40rpx 0;
}

.sku-group {
  margin-bottom: 40rpx;
}

.sku-title {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 20rpx;
  display: block;
}

.sku-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.sku-tag {
  padding: 16rpx 32rpx;
  background-color: #F7F7F7;
  color: #333333;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.sku-tag.active {
  background-color: #FFFFFF;
  color: #000000;
  border: 2rpx solid #000000;
  font-weight: 600;
}

.quantity-group {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.quantity-control {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.q-btn {
  width: 60rpx;
  height: 60rpx;
  background-color: #F7F7F7;
  color: #000000;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.q-num {
  width: 80rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.modal-footer {
  background-color: #FFFFFF;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom)) 30rpx;
  border-top: 1rpx solid #F0F0F0;
  flex-shrink: 0;
  z-index: 2;
}

.btn-primary {
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 500;
  padding: 24rpx 0;
  border: none;
  width: 100% !important;
}

.btn-primary:active {
  opacity: 0.8;
}

/* ================= 购物车明细列表 ================= */
.cart-detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 90;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.cart-content {
  position: relative;
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  display: flex;
  flex-direction: column;
  padding-bottom: calc(250rpx + env(safe-area-inset-bottom));
  overflow: hidden;
}

.cart-header {
  display: flex;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.cart-title {
  font-size: 32rpx;
  font-weight: 600;
}

.cart-clear {
  font-size: 26rpx;
  color: #999999;
}

.cart-list {
  padding: 0 40rpx;
  width: 100%;
  max-height: 50vh;
  box-sizing: border-box;
}

.cart-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  width: 100%;
}

.cart-item .item-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  width: 50%;
  flex-shrink: 0;
  padding-right: 20rpx;
  box-sizing: border-box;
}

.cart-item .item-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #000;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cart-item .item-custom {
  font-size: 22rpx;
  color: #999;
  margin: 6rpx 0;
  width: 100%;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cart-item .item-price {
  font-size: 28rpx;
  font-weight: 600;
}

.cart-item .quantity-control.mini-q {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  width: 50%;
  flex-shrink: 0;
}

.mini-q .q-btn {
  width: 48rpx;
  height: 48rpx;
  font-size: 32rpx;
  flex-shrink: 0 !important;
  background-color: #F7F7F7;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mini-q .q-num {
  width: 60rpx;
  font-size: 28rpx;
  text-align: center;
  flex-shrink: 0;
}

.mini-q .disabled {
  opacity: 0.3;
}

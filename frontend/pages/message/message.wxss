/* pages/message/message.wxss */
page {
  background-color: #F7F7F7;
  height: 100vh;
  overflow: hidden; 
}

.message-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 列表区 */
.message-list {
  flex: 1;
  height: 0;
  padding: 30rpx 30rpx 0 30rpx;
  box-sizing: border-box;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
  font-size: 26rpx;
  letter-spacing: 2rpx;
}

/* 高级白卡片 */
.message-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
}

.msg-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #000000;
}

.msg-time {
  font-size: 22rpx;
  color: #999999;
}

.msg-content {
  font-size: 30rpx;
  color: #333333;
  line-height: 1.6;
}

/* 商家回复区块 */
.reply-box {
  background-color: #F7F7F7;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 30rpx;
  display: flex;
  flex-direction: column;
}

.reply-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 10rpx;
}

.reply-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}

.bottom-spacer {
  height: 40rpx;
}

/* ================= 底部输入区 ================= */
.input-panel {
  flex-shrink: 0; 
  background-color: #FFFFFF;
  padding: 24rpx 30rpx calc(24rpx + env(safe-area-inset-bottom)) 30rpx;
  display: flex;
  align-items: flex-end; 
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.03);
  position: relative;
  z-index: 100;
}

/* 修复后的输入框：移除 fixed max-height，由 JS 控制 */
.msg-input {
  flex: 1;
  background-color: #FFFFFF;
  border: 2rpx solid #EAEAEA; 
  border-radius: 24rpx; 
  padding: 20rpx 30rpx; 
  font-size: 28rpx;
  color: #333333;
  line-height: 1.5;
  box-sizing: border-box;
}

/* 发送按钮保持在右下角 */
.btn-submit {
  background-color: #555555;
  color: #FFFFFF;
  border-radius: 40rpx; 
  font-size: 28rpx;
  font-weight: 500;
  width: 140rpx !important;
  height: 80rpx;
  line-height: 80rpx;
  margin-left: 20rpx; 
  margin-bottom: 0;   
  padding: 0;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0; 
}

.btn-submit:active {
  opacity: 0.8;
}
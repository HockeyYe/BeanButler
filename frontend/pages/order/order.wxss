/* pages/order/order.wxss */
page {
  background-color: #F7F7F7; 
  height: 100vh;
}

.order-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  height: 100rpx;
  flex-shrink: 0;
  position: relative;
  z-index: 10;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  color: #999999;
  position: relative;
  transition: color 0.2s;
}

.tab-item.active {
  color: #000000;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 50rpx;
  height: 6rpx;
  background-color: #000000;
  border-radius: 4rpx;
}

/* 订单列表 */
.order-list {
  flex: 1;
  padding: 24rpx 30rpx 180rpx 30rpx; 
  box-sizing: border-box;
  height: 0;
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999999;
  font-size: 28rpx;
}

/* ================= 新增：未登录提示的样式 ================= */
.login-prompt {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.prompt-text {
  margin-bottom: 40rpx;
  color: #666666;
}

.btn-login-black {
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
  width: 240rpx !important;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0;
  margin: 0;
}

.btn-login-black:active {
  opacity: 0.8;
}
/* ======================================================== */

.order-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 36rpx 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); 
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-left {
  display: flex;
  flex-direction: column;
}

.primary-info {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666666;
  margin-right: 16rpx;
}

.info-val {
  font-size: 44rpx; 
  font-weight: 600;
  color: #000000;
  letter-spacing: 2rpx;
}

.order-time {
  font-size: 24rpx;
  color: #999999;
}

.header-right {
  display: flex;
  align-items: center;
  height: 60rpx; 
}

.status-tag {
  font-size: 24rpx;
  font-weight: 700;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  color: #ffffff;
}

/* fallback classes kept for safety */
.status-tag.ongoing   { background-color: #E6A23C; }
.status-tag.completed { background-color: #67C23A; }
.status-tag.cancelled { background-color: #909399; }

.divider {
  height: 1rpx;
  background-color: #F0F0F0;
  margin: 30rpx 0;
}

.card-body {
  width: 100%;
}

.image-scroll {
  width: 100%;
  white-space: nowrap; 
}

.thumbnail {
  width: 130rpx;
  height: 130rpx;
  border-radius: 12rpx;
  background-color: #F7F7F7;
  margin-right: 20rpx;
  display: inline-block; 
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-items {
  font-size: 26rpx;
  color: #666666;
}

.price-wrap {
  display: flex;
  align-items: baseline;
}

.price-label {
  font-size: 26rpx;
  color: #333333;
  margin-right: 12rpx;
}

.price-val {
  font-size: 36rpx;
  font-weight: 600;
  color: #000000;
}
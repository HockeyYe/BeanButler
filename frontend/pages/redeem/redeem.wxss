/* pages/redeem/redeem.wxss */
page {
  background-color: #F7F7F7;
  height: 100vh;
}

.redeem-container {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* 积分头部 - 纯黑卡片 */
.points-header {
  background-color: #000000;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);
}

.points-info {
  display: flex;
  flex-direction: column;
}

.points-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  margin-bottom: 10rpx;
}

.points-value {
  font-size: 64rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.points-coffee-icon {
  width: 70rpx;  /* 宽度 */
  height: 70rpx; /* 高度 */
  margin-top: 45rpx;
}

/* 兑换列表区 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 30rpx;
  display: block;
}

/* 券卡片 (取代旧版的网格图片流) */
.redeem-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.card-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding-right: 20rpx;
  border-right: 2rpx dashed #EEEEEE; /* 极细分割线 */
}

.redeem-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  margin-bottom: 12rpx;
}

.redeem-desc {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.redeem-validity {
  font-size: 22rpx;
  color: #999999;
}

.card-right {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-left: 20rpx;
  flex-shrink: 0;
}

.points-cost {
  margin-bottom: 20rpx;
  display: flex;
  align-items: baseline;
}

.points-cost .num {
  font-size: 40rpx;
  font-weight: 600;
  color: #000000;
  margin-right: 6rpx;
}

.points-cost .unit {
  font-size: 22rpx;
  color: #666666;
}

/* 黑底极简按钮 */
.exchange-btn {
  background-color: #000000;
  color: #FFFFFF;
  border-radius: 40rpx;
  font-size: 26rpx;
  padding: 12rpx 0;
  width: 140rpx !important;
  margin: 0;
  border: none;
  font-weight: 500;
}

.exchange-btn:active {
  opacity: 0.8;
}

/* 积分不足时的禁用状态 */
.exchange-btn.disabled {
  background-color: #F5F5F5;
  color: #CCCCCC;
}